# ---- Mumbai Eye Retina Clinic: front-controller routing ----
Options -Indexes
DirectoryIndex index.php

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /mumbai-eye-retina-clinic-fixed/

  # Serve real existing files/assets directly
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Everything else goes through the front controller
  RewriteRule ^ index.php [L]
</IfModule>

# Protect data files from direct web access
<FilesMatch "\.(json)$">
  Require all denied
</FilesMatch>
